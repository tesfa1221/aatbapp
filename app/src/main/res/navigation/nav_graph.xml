<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment android:id="@+id/homeFragment"
        android:name="com.example.aatbapp.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home" />

    <fragment android:id="@+id/scanFragment"
        android:name="com.example.aatbapp.ScanFragment"
        android:label="Scan"
        tools:layout="@layout/fragment_scan" />

    <fragment android:id="@+id/platesFragment"
        android:name="com.example.aatbapp.PlatesFragment"
        android:label="Plates"
        tools:layout="@layout/fragment_plates" />

    <fragment android:id="@+id/notificationsFragment"
        android:name="com.example.aatbapp.NotificationsFragment"
        android:label="Notifications"
        tools:layout="@layout/fragment_notifications" />

    <fragment android:id="@+id/profileFragment"
        android:name="com.example.aatbapp.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile" />

    <fragment
        android:id="@+id/FirstFragment"
        android:name="com.example.aatbapp.FirstFragment"
        android:label="First Fragment"
        tools:layout="@layout/fragment_first">
        <action
            android:id="@+id/action_FirstFragment_to_SecondFragment"
            app:destination="@id/SecondFragment" />
    </fragment>

    <fragment
        android:id="@+id/SecondFragment"
        android:name="com.example.aatbapp.SecondFragment"
        android:label="Second Fragment"
        tools:layout="@layout/fragment_second">
        <action
            android:id="@+id/action_SecondFragment_to_FirstFragment"
            app:destination="@id/FirstFragment" />
    </fragment>

</navigation>
